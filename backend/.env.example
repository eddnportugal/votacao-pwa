DJANGO_ENV=production
DJANGO_SECRET_KEY=change-me-in-production-use-a-real-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=votacao.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://votacao.example.com
DATABASE_URL=postgresql://votacao:votacao@localhost:5432/votacao_db
CORS_ALLOWED_ORIGINS=https://votacao.example.com
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
FRONTEND_APP_URL=https://votacao.example.com
WEBAUTHN_RP_ID=votacao.example.com
WEBAUTHN_RP_NAME=Votação Online
WEBAUTHN_ORIGIN=https://votacao.example.com
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=change-me
DEFAULT_FROM_EMAIL=noreply@votacao.example.com
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
